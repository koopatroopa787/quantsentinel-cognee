# QuantSentinel — Environment Variables Template
# Copy this file to backend/.env and fill in your real values.
# NEVER commit the real .env to version control.

# ── Google Cloud / Vertex AI ─────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE

# ── Direct Gemini API (alternative to Vertex AI — leave blank if using Vertex) ─
GEMINI_API_KEY=
GOOGLE_API_KEY=

# ── Arize Phoenix Cloud ───────────────────────────────────────────────────────
PHOENIX_API_KEY=your-phoenix-api-key
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com/s/your-space/v1/traces
PHOENIX_BASE_URL=https://app.phoenix.arize.com
PHOENIX_PROJECT_NAME=quantsentinel

# ── External Data APIs ────────────────────────────────────────────────────────
FRED_API_KEY=your-fred-api-key

# ── App Runtime ───────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
MAX_BACKTEST_ROWS=50000
EVAL_SCORE_THRESHOLD=0.70
MAX_CRITIQUE_LOOPS=3
OPTIMIZER_MODEL=gemini-3-flash-preview
